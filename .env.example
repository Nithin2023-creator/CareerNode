# ────────────────────────────────────────────────────
# CareerNode Frontend — EXAMPLE CONFIGURATION
# ────────────────────────────────────────────────────
# Vite env loading order:
#   .env              — always loaded (shared defaults)
#   .env.local        — loaded during `vite` / `vite dev` (local overrides)
#   .env.production   — loaded during `vite build` (prod overrides)
#
# Copy relevant values to .env.local for dev or .env.production for prod.

# Base URL of the CareerNode backend API
VITE_API_BASE_URL=http://localhost:5000/api
# Production: VITE_API_BASE_URL=https://careernode.dev/api

# Job Finder microservice (if separate)
VITE_JOB_FINDER_API_BASE_URL=http://localhost:5002/api
# Production: VITE_JOB_FINDER_API_BASE_URL=https://careernode.dev/api

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Cashfree checkout mode: 'sandbox' or 'production'
VITE_CASHFREE_MODE=sandbox
# Production: VITE_CASHFREE_MODE=production
