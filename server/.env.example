# ────────────────────────────────────────────────────
# CareerNode Server — EXAMPLE CONFIGURATION
# ────────────────────────────────────────────────────
# Copy this to .env.local (for dev) or .env.production (for prod).
# The server loads: .env.<local|production> first, then .env as fallback.

# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
# Production: CLIENT_ORIGIN=https://careernode.dev

# Database
MONGODB_URI=mongodb://localhost:27017/carrernode

# AI (Groq) - used for CSV column mapping and row cleaning
GROQ_API_KEY=your_groq_api_key_here

# Authentication
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
TOKEN_ENCRYPTION_KEY=your_32_char_encryption_key_here

# Cashfree Payments
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=SANDBOX
# Production: CASHFREE_ENV=PRODUCTION
CASHFREE_API_VERSION=2025-01-01
SERVER_PUBLIC_URL=http://localhost:5000
# Production: SERVER_PUBLIC_URL=https://careernode.dev
USD_TO_INR_RATE=83
